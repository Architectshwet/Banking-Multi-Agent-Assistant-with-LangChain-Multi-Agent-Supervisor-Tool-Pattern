# PostgreSQL Database Configuration
# Example:
# POSTGRESQL_URL=postgresql://user:password@host:5432/dbname?sslmode=require
POSTGRESQL_URL=

# Application Configuration
PYTHONPATH=/app
PYTHONUNBUFFERED=1
ENABLE_SESSION_SYNC=true
LANGGRAPH_DEV=true

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_TEMPERATURE=0.1

# Optional observability
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Default demo user
BANKING_DEFAULT_CUSTOMER_ID=CUST1001

# CORS allowlist
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
